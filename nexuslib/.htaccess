
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /nexuslib/

# Excluir carpetas reales de reescritura (archivos y carpetas que existen físicamente)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Excluir explícitamente las carpetas de servicios y assets
RewriteRule ^(services|src/assets)/(.*)$ $0 [L]

# Reescribir la raíz del proyecto a src/Views/search/index.php de forma transparente.
RewriteRule ^$ src/Views/search/index.php [L]

# Enviar URLs amigables al front controller.
RewriteRule ^(.+)$ index.php?url=$1 [QSA,L]
</IfModule>
